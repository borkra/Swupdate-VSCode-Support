{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "compile",
			"type": "npm",
			"script": "compile",
			"group": "build",
			"presentation": {
				"panel": "dedicated",
				"reveal": "never"
			},
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "watch",
			"type": "npm",
			"script": "watch",
			"isBackground": true,
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"panel": "dedicated",
				"reveal": "never"
			},
			"problemMatcher": [
				"$tsc-watch"
			]
		},
		{
			"label": "test",
			"type": "npm",
			"script": "test",
			"options": {
				"env": {
					"LIBCONFIG_VSIX_PATH": "${workspaceFolder}/../Libconfig-VsCode-Support/libconfig-lang.vsix"
				}
			},
			"group": "test",
			"presentation": {
				"panel": "dedicated",
				"reveal": "always"
			}
		},
		{
			"label": "install:local",
			"type": "npm",
			"script": "install:local",
			"group": "build",
			"presentation": {
				"panel": "dedicated",
				"reveal": "always"
			}
		},
		{
			"label": "bundle",
			"type": "npm",
			"script": "bundle",
			"group": "build",
			"presentation": {
				"panel": "dedicated",
				"reveal": "always"
			}
		},
		{
			"label": "package:local",
			"type": "npm",
			"script": "package:local",
			"group": "build",
			"presentation": {
				"panel": "dedicated",
				"reveal": "always"
			}
		},
		{
			"label": "clean",
			"type": "npm",
			"script": "clean",
			"presentation": {
				"panel": "dedicated",
				"reveal": "always"
			}
		},
		{
			"label": "clean:full",
			"type": "npm",
			"script": "clean:full",
			"presentation": {
				"panel": "dedicated",
				"reveal": "always"
			}
		},
		{
			"label": "update:version",
			"type": "npm",
			"script": "update:version",
			"presentation": {
				"panel": "dedicated",
				"reveal": "always"
			}
		}
	]
}